#!/bin/bash
# Agent Witch Installer — Install or Update without Terminal copy-paste
set -euo pipefail

ORIGIN="__AGENT_WITCH_ORIGIN__"
INSTALL_DIR_NAME="__AGENT_WITCH_INSTALL_DIR_NAME__"
INSTALL_URL="${ORIGIN%/}/install/agent-witch.sh"
INSTALL_DIR="${HOME}/${INSTALL_DIR_NAME}"
SELF_UPDATE_SH="${INSTALL_DIR}/self-update.sh"
LOG_FILE="${TMPDIR:-/tmp}/agent-witch-installer.log"
PRODUCT_NAME="Agent Witch"

is_installed() {
  [[ -d "${INSTALL_DIR}" ]] && [[ -f "${INSTALL_DIR}/agent-witch.ts" || -f "${SELF_UPDATE_SH}" ]]
}

choose_action() {
  if is_installed; then
    local result
    result="$(
      osascript <<EOF
display dialog "${PRODUCT_NAME} is already installed at:
${INSTALL_DIR}

Install refreshes from ${ORIGIN}.
Update checks the install bundle and applies a newer version when available." \
  with title "${PRODUCT_NAME} Installer" \
  buttons {"Cancel", "Install", "Update"} \
  default button "Update"
EOF
    )" || return 1
    if [[ "$result" == *"Update"* ]]; then
      echo "update"
      return 0
    fi
    if [[ "$result" == *"Install"* ]]; then
      echo "install"
      return 0
    fi
    return 1
  fi

  local result
  result="$(
    osascript <<EOF
display dialog "Install ${PRODUCT_NAME} on this Mac?

This downloads the install script from:
${ORIGIN}

Background helpers start at login so you can send tasks from the browser." \
  with title "${PRODUCT_NAME} Installer" \
  buttons {"Cancel", "Install"} \
  default button "Install"
EOF
  )" || return 1
  [[ "$result" == *"Install"* ]] || return 1
  echo "install"
}

run_install() {
  /bin/zsh -lc "curl -fsSL $(printf '%q' "$INSTALL_URL") | bash" >"$LOG_FILE" 2>&1
}

run_update() {
  if [[ -x "${SELF_UPDATE_SH}" ]]; then
    /bin/zsh -lc "$(printf '%q' "${SELF_UPDATE_SH}")" >"$LOG_FILE" 2>&1
    return $?
  fi
  # Fresh installs without self-update.sh yet: re-run the published install script.
  run_install
}

show_success() {
  local action_label="$1"
  local next
  next="$(
    osascript <<EOF
display dialog "${PRODUCT_NAME} ${action_label}.

Next: open ${ORIGIN} in your browser and link this Mac if needed.

A log was saved to:
${LOG_FILE}" \
  with title "${PRODUCT_NAME} Installer" \
  buttons {"Close", "Open ${PRODUCT_NAME}"} \
  default button "Open ${PRODUCT_NAME}"
EOF
  )" || true
  if [[ "${next:-}" == *"Open"* ]]; then
    open "${ORIGIN%/}/"
  fi
}

show_failure() {
  local action_label="$1"
  osascript <<EOF
display dialog "${PRODUCT_NAME} ${action_label} failed.

Check the log:
${LOG_FILE}

You can also run from Terminal:
curl -fsSL ${INSTALL_URL} | bash
# or, if already installed:
${SELF_UPDATE_SH}" \
  with title "${PRODUCT_NAME} Installer" \
  buttons {"OK"} \
  default button "OK"
EOF
}

main() {
  local action
  action="$(choose_action)" || exit 0

  if [[ "$action" == "update" ]]; then
    osascript -e "display notification \"Updating ${PRODUCT_NAME}…\" with title \"${PRODUCT_NAME}\"" || true
    if run_update; then
      show_success "is up to date"
      exit 0
    fi
    show_failure "update"
    exit 1
  fi

  osascript -e "display notification \"Installing ${PRODUCT_NAME}…\" with title \"${PRODUCT_NAME}\"" || true
  if run_install; then
    show_success "is installed"
    exit 0
  fi
  show_failure "install"
  exit 1
}

main "$@"
