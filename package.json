{
  "name": "daily-magic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "dev:next": "next dev",
    "build": "next build",
    "vercel-build": "npm run db:migrate && next build",
    "start": "NODE_ENV=production tsx server.ts",
    "start:with-migrate": "npm run db:migrate && npm run start",
    "agent-witch": "tsx scripts/agent-witch.ts",
    "agent-witch:wake-server": "tsx scripts/agent-witch-wake-server.ts",
    "agent-witch:watchdog": "tsx scripts/agent-witch-watchdog.ts",
    "agent-witch:automation-scheduler": "tsx scripts/agent-witch-automation-scheduler.ts",
    "agent-witch:self-update": "tsx scripts/agent-witch-self-update.ts",
    "agent-witch:test-writer-session-stream": "tsx scripts/testWriterSessionStreamLocal.ts",
    "agent-witch:install": "bash scripts/install-agent-witch.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "showcase:capture": "node .agents/scripts/capture-showcase-screens.mjs",
    "e2e:capture-screenshots": "playwright test e2e/capture-e2e-screenshots.spec.ts",
    "e2e:agent-witch:setup": "tsx scripts/e2e-setup-agent-witch-localhost.ts",
    "lint": "eslint",
    "typecheck": "npm run lint && tsc --noEmit",
    "db:schema": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:migrate:bootstrap": "tsx scripts/db-migrate-bootstrap.ts",
    "db:migrate:onboarding-first-task": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f db/migrations/013-onboarding-first-task-sent.sql",
    "prepare": "npx is-ci || npx husky",
    "cursor:verify": "tsx .agents/scripts/verify-rules.ts",
    "cursor:architecture": "tsx .agents/scripts/architecture-check.ts",
    "ci:architecture": "tsx .agents/scripts/architecture-check.ts --base=origin/main",
    "validate:staged": "sh .agents/scripts/validate-structure-staged.sh",
    "validate:all": "find src db -type f \\( -name '*.ts' -o -name '*.tsx' -o -name '*.sql' \\) -print0 | xargs -0 npx structure-validation --files --verify-root --skip-error",
    "validate:fix": "structure-validation --scope staged --fix --verify-root",
    "validate:preview": "structure-validation --scope staged --dry-run",
    "feature-knowledge:index": "tsx .agents/scripts/feature-knowledge-index.ts",
    "feature-knowledge:query": "tsx .agents/scripts/feature-knowledge-query.ts",
    "feature-knowledge:scaffold-docs": "tsx .agents/scripts/feature-knowledge-scaffold-docs.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@next/third-parties": "^16.2.10",
    "@tailwindcss/forms": "^0.5.11",
    "apexcharts": "^5.16.0",
    "flatpickr": "^4.6.13",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.4",
    "react-apexcharts": "^2.1.1",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "resend": "^6.17.2",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.20.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "prettier": "^3.6.2",
    "structure-validation": "^0.0.14",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
