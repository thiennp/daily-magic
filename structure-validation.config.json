{
  "root": ".",
  "structure": {
    "src/app": [
      "page.tsx",
      "layout.tsx",
      "loading.tsx",
      "error.tsx",
      "not-found.tsx",
      "route.ts",
      "globals.css"
    ],
    "src/features": ["*.tsx"],
    "src/hooks": ["use*.ts"],
    "src/lib": ["*.ts"],
    "src/server": ["*.ts"],
    "src/context": ["*.tsx"],
    "src/icons": ["*.svg", "index.tsx"],
    "src/components": ["*.tsx"],
    "db": ["*.sql"],
    "{a}": ["{a}.ts", "{a}.tsx", "{a}.module.css", "{a}.*.ts", "{a}.*.tsx"],
    "{root}": [
      "package.json",
      "tsconfig.json",
      "next.config.ts",
      "README.md",
      "structure-validation.config.json",
      "structure-validation.skip.json",
      "eslint.config.mjs",
      "postcss.config.mjs",
      "vercel.json",
      ".env.example",
      "CLAUDE.md",
      "AGENTS.md"
    ],
    "**": ["*.test.ts", "*.test.tsx", "index.ts", "index.tsx"]
  }
}
