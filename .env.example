# Neon PostgreSQL connection string
# Create a project at https://console.neon.tech and copy the connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js / NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Dev-only: instant email login when localStorage secret matches SECRET.
# Only SECRET + DATABASE_URL are required for secret login.
# localStorage.setItem("secret", "<same value as SECRET>")
SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email magic links (Resend) — https://resend.com/api-keys
AUTH_RESEND_KEY="re_xxxxxxxx"
EMAIL_FROM="Daily Magic <noreply@your-verified-domain.com>"

# Optional: unpooled connection for migrations or one-off scripts
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Agent Witch requires the custom Node server (npm run start), not Vercel serverless.
# Deploy www.agentwitch.com on Railway/Render/Fly.io/VPS using the Dockerfile.
# Railway injects PORT=8080 at runtime — set each custom domain target port to 8080,
# or add a service variable PORT=3000 if you keep target port 3000.
# AGENT_WITCH_WS_URL is optional when the websocket lives on the same origin.
# AGENT_WITCH_WS_URL="wss://agentwitch.com/api/agent-witch/ws"
# Dev-only: mock paired devices API without DB (all-online | all-offline | mixed | no-devices | api-error | ws-disconnected)
# AGENT_WITCH_MOCK_SCENARIO="mixed"
# CLAUDE_COMMAND="claude"
# Re-run install/agent-witch.sh to generate pairingToken in ~/.agent-witch/config.json
