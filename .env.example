# Neon PostgreSQL connection string
# Create a project at https://console.neon.tech and copy the connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js / NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="https://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email magic links (Resend) — https://resend.com/api-keys
AUTH_RESEND_KEY="re_xxxxxxxx"
EMAIL_FROM="Daily Magic <noreply@your-verified-domain.com>"

# Optional: unpooled connection for migrations or one-off scripts
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Public app URL used when host headers are unavailable
NEXT_PUBLIC_APP_URL="https://agentwitch.com"

# Agent Witch WebSocket path (custom server)
# AGENT_WITCH_WS_PATH="/api/agent-witch/ws"
# Local agent profile (multi-account on one computer)
# AGENT_WITCH_PROFILE="you@example.com"

# Local agent client (scripts/agent-witch.ts)
# AGENT_WITCH_WS_URL="wss://agentwitch.com/api/agent-witch/ws"
# CLAUDE_COMMAND="claude"
# Re-run install/agent-witch.sh to generate pairingToken in ~/.agent-witch/config.json
